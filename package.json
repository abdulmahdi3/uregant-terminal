{
  "name": "urterminal",
  "version": "0.2.1",
  "description": "Multi-pane AI + shell terminal",
  "main": "./out/main/index.js",
  "author": "URterminal",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "rebuild": "node scripts/setup-natives.mjs",
    "postinstall": "node scripts/setup-natives.mjs",
    "pack:win": "electron-vite build && electron-builder --win --config electron-builder.yml",
    "publish:win": "electron-vite build && electron-builder --win --config electron-builder.yml --publish always"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.12.0",
    "clsx": "^2.1.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "grammy": "^1.30.0",
    "lucide-react": "^0.460.0"
  },
  "devDependencies": {
    "@tanstack/react-virtual": "^3.10.8",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/xterm": "^5.5.0",
    "electron": "^39.8.5",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "i18next": "^23.15.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.0.2",
    "react-mosaic-component": "^6.1.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "zustand": "^4.5.5"
  }
}
